#!/bin/sh

UTS_MACHINE=$1
CC_VERSION="$2"
LD=$3

if test -z "$KBUILD_BUILD_USER"; then
	BAREBOX_COMPILE_BY=$(whoami | sed 's/\\/\\\\/')
else
	BAREBOX_COMPILE_BY=$KBUILD_BUILD_USER
fi
if test -z "$KBUILD_BUILD_HOST"; then
	BAREBOX_COMPILE_HOST=`uname -n`
else
	BAREBOX_COMPILE_HOST=$KBUILD_BUILD_HOST
fi

BUILDSYSTEM_VERSION="$BUILDSYSTEM_VERSION"

LD_VERSION=$(LC_ALL=C $LD -v | head -n1 |
		sed -e 's/(compatible with [^)]*)//' -e 's/[[:space:]]*$//')

cat <<EOF
#define UTS_MACHINE "$ARCH"
#define BUILDSYSTEM_VERSION "$BUILDSYSTEM_VERSION"
#define BAREBOX_COMPILE_BY "$BAREBOX_COMPILE_BY"
#define BAREBOX_COMPILE_HOST "$BAREBOX_COMPILE_HOST"
#define BAREBOX_COMPILER "${CC_VERSION}, ${LD_VERSION}"
EOF
